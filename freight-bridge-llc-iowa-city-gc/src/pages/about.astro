---
import Base from '@engine/layouts/Base.astro';
import { getEntry } from 'astro:content';

const businessEntry = await getEntry('business', 'biz');
const business = businessEntry?.data;
---

<Base title={`About Us | ${business?.name}`} description={`Learn about ${business?.name}. ${business?.tagline}`}>
  <section class="hero">
    <h1>About {business?.name}</h1>
    <p class="tagline">{business?.tagline}</p>
  </section>

  <section class="story">
    <div class="story-content">
      <h2>Our Story</h2>
      <p>
        Freight Bridge Cleanup Services is the post-construction cleanup arm of Freight Bridge LLC,
        a boutique Iowa-based freight carrier. When the data center boom hit the Iowa City corridor —
        with QTS, Google, and other operators building out the Cedar Rapids region — we expanded into
        post-construction cleanup to put our box truck and crews to work on the back end of those builds.
      </p>
      <p>
        We're small, local, and owner-run. When you call, you talk to the owner. When the crew shows up,
        it's the same people every time. We come in after the trades wrap up, haul the construction debris
        out with our box truck, sweep out the building, and hand it back commissioning-ready.
      </p>
    </div>
  </section>

  <section class="values">
    <h2>How We Work</h2>
    <div class="values-grid">
      <div class="value-card">
        <h3>One Phone Call</h3>
        <p>Call the office, talk to the owner, get a flat-price quote after a site walk-through. No layers, no salespeople.</p>
      </div>
      <div class="value-card">
        <h3>Our Own Truck</h3>
        <p>We haul construction debris off-site with our own box truck — no waiting on third-party dumpster pickups or extra subcontractors.</p>
      </div>
      <div class="value-card">
        <h3>What We Promise</h3>
        <ul>
          <li>Show up when we say we will</li>
          <li>Quote the job flat — no surprises</li>
          <li>Leave the space ready for commissioning</li>
          <li>Owner answers the phone, every time</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="team">
    <h2>Leadership Team</h2>
    <div class="team-grid">
      <div class="team-card">
        <div class="team-avatar">MS</div>
        <h3>Mohamed Soliman</h3>
        <p class="role">Owner — Office & Operations</p>
        <p>Runs the office: takes the calls, books the walk-throughs, prepares the quotes, and coordinates schedules. Our cleanup crews handle the work on site.</p>
      </div>
      <div class="team-card">
        <div class="team-avatar">FB</div>
        <h3>Cleanup Crew</h3>
        <p class="role">Field Team</p>
        <p>Experienced cleanup crews handle every job on site — debris haul-off, sweep-out, and final post-construction cleanup with our box truck.</p>
      </div>
    </div>
  </section>

  <section class="stats">
    <h2>The Basics</h2>
    <div class="stats-grid">
      <div class="stat">
        <span class="stat-value">3</span>
        <span class="stat-label">Cities Served — Iowa City, Coralville, North Liberty</span>
      </div>
      <div class="stat">
        <span class="stat-value">1</span>
        <span class="stat-label">Box Truck for Debris Haul-Off</span>
      </div>
      <div class="stat">
        <span class="stat-value">Flat</span>
        <span class="stat-label">Quote — No Hourly Surprises</span>
      </div>
      <div class="stat">
        <span class="stat-value">Owner</span>
        <span class="stat-label">Answers Every Call</span>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <h2>Ready to Schedule Cleanup?</h2>
    <p>Call the office and ask for Mohamed at {business?.phone}. We'll book a site walk-through and get you a flat-price quote.</p>
    <a href="/contact" class="cta-btn">Get a Quote</a>
  </section>
</Base>

<style>
  .hero {
    padding: 4rem 0 2rem;
    text-align: center;
  }
  h1 {
    font-size: 2.5rem;
    margin: 0 0 1rem;
    color: #1e3a8a;
  }
  .tagline {
    font-size: 1.25rem;
    color: #6b7280;
    margin: 0;
  }
  h2 {
    font-size: 1.75rem;
    margin: 0 0 1.5rem;
    color: #111827;
  }

  .story {
    padding: 2rem 0;
    max-width: 48rem;
    margin: 0 auto;
  }
  .story p {
    line-height: 1.8;
    color: #374151;
    margin: 0 0 1rem;
  }

  .values {
    padding: 3rem 0;
  }
  .values-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .value-card {
    background: #f0f9ff;
    padding: 2rem;
    border-radius: 0.75rem;
    border: 1px solid #bfdbfe;
  }
  .value-card h3 {
    color: #2563eb;
    margin: 0 0 0.75rem;
  }
  .value-card p, .value-card ul {
    color: #374151;
    line-height: 1.6;
    margin: 0;
  }
  .value-card ul {
    padding-left: 1.25rem;
  }
  .value-card li {
    margin-bottom: 0.5rem;
  }

  .team {
    padding: 3rem 0;
  }
  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }
  .team-card {
    text-align: center;
    padding: 2rem;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
  }
  .team-avatar {
    width: 4rem;
    height: 4rem;
    background: #2563eb;
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.25rem;
    margin: 0 auto 1rem;
  }
  .team-card h3 {
    margin: 0 0 0.25rem;
    color: #111827;
  }
  .role {
    color: #2563eb;
    font-weight: 600;
    margin: 0 0 0.75rem;
    font-size: 0.875rem;
  }
  .team-card p:last-child {
    color: #6b7280;
    line-height: 1.5;
    margin: 0;
  }

  .stats {
    padding: 3rem 0;
    text-align: center;
  }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 1.5rem;
  }
  .stat {
    padding: 1.5rem;
    background: #1e3a8a;
    color: white;
    border-radius: 0.75rem;
  }
  .stat-value {
    display: block;
    font-size: 2.25rem;
    font-weight: 800;
    margin-bottom: 0.25rem;
  }
  .stat-label {
    font-size: 0.875rem;
    opacity: 0.9;
  }

  .cta-section {
    text-align: center;
    padding: 3rem 2rem;
    background: #f0f9ff;
    border-radius: 1rem;
    margin: 2rem 0;
  }
  .cta-section p {
    color: #374151;
    margin: 0 0 1.5rem;
    font-size: 1.1rem;
  }
  .cta-btn {
    display: inline-block;
    background: #2563eb;
    color: white;
    padding: 0.75rem 2rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.1rem;
  }
  .cta-btn:hover {
    background: #1e40af;
  }
</style>

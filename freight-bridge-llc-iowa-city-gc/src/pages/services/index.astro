---
import Base from '@engine/layouts/Base.astro';
import { getEntry, getCollection } from 'astro:content';

const businessEntry = await getEntry('business', 'biz');
const business = businessEntry?.data;
const services = await getCollection('services');
---

<Base title={`Our Services | ${business?.name}`} description={`${business?.name} offers fast shipment, freight management, and custom logistics solutions across the United States.`}>
  <section class="hero">
    <h1>Our Services</h1>
    <p class="subtitle">Comprehensive freight and logistics solutions tailored to your business needs</p>
  </section>

  <section class="services-grid">
    {services.map((service) => (
      <a href={`/services/${service.data.slug}`} class="service-card">
        <div class="service-icon">{
          service.data.slug === 'fast-shipment' ? '🚛' :
          service.data.slug === 'freight-management' ? '📊' : '⚙️'
        }</div>
        <h2>{service.data.name}</h2>
        <p>{service.data.description}</p>
        <span class="learn-more">Learn More →</span>
      </a>
    ))}
  </section>

  <section class="benefits">
    <h2>Why Choose {business?.name}?</h2>
    <div class="benefits-grid">
      <div class="benefit">
        <span class="benefit-icon">✓</span>
        <div>
          <h3>Proven Results</h3>
          <p>99.8% on-time delivery rate with an average 25% reduction in logistics costs for our clients.</p>
        </div>
      </div>
      <div class="benefit">
        <span class="benefit-icon">✓</span>
        <div>
          <h3>Extensive Network</h3>
          <p>Nationwide coverage across all major U.S. markets with regional hubs for faster service.</p>
        </div>
      </div>
      <div class="benefit">
        <span class="benefit-icon">✓</span>
        <div>
          <h3>Dedicated Support</h3>
          <p>24/7 customer support with dedicated account managers who know your business.</p>
        </div>
      </div>
      <div class="benefit">
        <span class="benefit-icon">✓</span>
        <div>
          <h3>Advanced Technology</h3>
          <p>Real-time GPS tracking, AI-powered route optimization, and predictive analytics.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="process">
    <h2>How It Works</h2>
    <div class="steps">
      <div class="step">
        <span class="step-num">1</span>
        <h3>Request a Quote</h3>
        <p>Tell us about your shipping needs and we'll provide a competitive quote within hours.</p>
      </div>
      <div class="step">
        <span class="step-num">2</span>
        <h3>Plan & Optimize</h3>
        <p>Our team designs the optimal route and logistics strategy for your shipment.</p>
      </div>
      <div class="step">
        <span class="step-num">3</span>
        <h3>Ship & Track</h3>
        <p>Your freight moves with real-time tracking and proactive status updates.</p>
      </div>
      <div class="step">
        <span class="step-num">4</span>
        <h3>Deliver & Report</h3>
        <p>On-time delivery with detailed analytics and performance reporting.</p>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <h2>Ready to Get Started?</h2>
    <p>Contact us today for a free logistics consultation and competitive quote.</p>
    <div class="cta-buttons">
      <a href="/contact" class="cta-btn primary">Get a Quote</a>
      <a href={`tel:${business?.phone}`} class="cta-btn secondary">Call {business?.phone}</a>
    </div>
  </section>
</Base>

<style>
  .hero {
    padding: 4rem 0 2rem;
    text-align: center;
  }
  h1 {
    font-size: 2.5rem;
    margin: 0 0 1rem;
    color: #1e3a8a;
  }
  .subtitle {
    font-size: 1.2rem;
    color: #6b7280;
    margin: 0;
  }
  h2 {
    font-size: 1.75rem;
    color: #111827;
    margin: 0 0 1.5rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
    padding: 2rem 0;
  }
  .service-card {
    display: block;
    padding: 2rem;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .service-card:hover {
    border-color: #2563eb;
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.1);
  }
  .service-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }
  .service-card h2 {
    font-size: 1.35rem;
    margin: 0 0 0.75rem;
    color: #1e3a8a;
  }
  .service-card p {
    color: #6b7280;
    line-height: 1.6;
    margin: 0 0 1rem;
    font-size: 0.95rem;
  }
  .learn-more {
    color: #2563eb;
    font-weight: 600;
    font-size: 0.9rem;
  }

  .benefits {
    padding: 3rem 0;
  }
  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .benefit {
    display: flex;
    gap: 1rem;
    padding: 1.5rem;
    background: #f9fafb;
    border-radius: 0.5rem;
  }
  .benefit-icon {
    color: #10b981;
    font-size: 1.25rem;
    font-weight: 700;
    flex-shrink: 0;
  }
  .benefit h3 {
    margin: 0 0 0.5rem;
    font-size: 1rem;
    color: #111827;
  }
  .benefit p {
    margin: 0;
    color: #6b7280;
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .process {
    padding: 3rem 0;
    text-align: center;
  }
  .steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
  }
  .step {
    padding: 1.5rem;
  }
  .step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    background: #2563eb;
    color: white;
    border-radius: 50%;
    font-weight: 700;
    margin-bottom: 1rem;
  }
  .step h3 {
    margin: 0 0 0.5rem;
    color: #111827;
  }
  .step p {
    margin: 0;
    color: #6b7280;
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .cta-section {
    text-align: center;
    padding: 3rem 2rem;
    background: #1e3a8a;
    color: white;
    border-radius: 1rem;
    margin: 2rem 0;
  }
  .cta-section h2 {
    color: white;
  }
  .cta-section p {
    opacity: 0.9;
    margin: 0 0 1.5rem;
    font-size: 1.1rem;
  }
  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .cta-btn {
    display: inline-block;
    padding: 0.75rem 2rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
  }
  .cta-btn.primary {
    background: #2563eb;
    color: white;
  }
  .cta-btn.secondary {
    background: transparent;
    color: white;
    border: 2px solid white;
  }
</style>

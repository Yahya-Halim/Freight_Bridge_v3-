---
import Base from '@engine/layouts/Base.astro';
import { getEntry } from 'astro:content';

const businessEntry = await getEntry('business', 'biz');
const business = businessEntry?.data;
---

<Base title={`About Us | ${business?.name}`} description={`Learn about ${business?.name}, a trusted moving and freight hauling company in ${business?.address.city}, ${business?.address.state}, with a team that treats every load like their own.`}>
  <section class="hero">
    <h1>About {business?.name}</h1>
    <p class="tagline">{business?.tagline}</p>
  </section>

  <section class="story">
    <div class="story-content">
      <h2>Our Story</h2>
      <p>
        {business?.name} is a trusted moving and freight hauling company based in
        {business?.address.city}, {business?.address.state}. We're not a national chain or a call
        center — when you hire us, you work with a dedicated team that handles your move
        and stands behind every load.
      </p>
      <p>
        As an authorized interstate carrier (USDOT 4414774, MC-1734786), we can legally move
        households and businesses across state lines, not just locally. Alongside residential and
        commercial moving, we haul freight in all 50 states for brokers and dispatchers with our own
        truck and provide post-construction hauling for data center projects across the Iowa City and Cedar Rapids corridor.
      </p>
    </div>
  </section>

  <section class="values">
    <h2>What We Stand For</h2>
    <div class="values-grid">
      <div class="value-card">
        <h3>Hands-On Service</h3>
        <p>Our team is on every job. You get people who know your move from start to finish — not a faceless call center.</p>
      </div>
      <div class="value-card">
        <h3>Honest & Reliable</h3>
        <p>Straight quotes, careful handling of your belongings, and no surprises on moving day.</p>
      </div>
      <div class="value-card">
        <h3>Licensed & Insured</h3>
        <p>A fully authorized interstate carrier so your move is covered whether it's across town or across the country.</p>
      </div>
    </div>
  </section>

  <section class="owner">
    <h2>Our Team</h2>
    <div class="owner-card">
      <div class="owner-avatar">FB</div>
      <div>
        <h3>The Freight Bridge Team</h3>
        <p class="role">Movers · Haulers · Drivers</p>
        <p>{business?.name} was founded to do moving and hauling the way it should be done — hands-on, dependable, and personal. Our experienced crew handles the quotes, runs the jobs, and stands behind every load.</p>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <h2>Ready to work with us?</h2>
    <p>Get in touch with {business?.name} for a straight quote on your move or freight needs.</p>
    <a href="/contact" class="cta-btn">Get a Quote</a>
  </section>
</Base>

<style>
  .hero { padding: 4rem 0 2rem; text-align: center; }
  h1 { font-size: 2.5rem; margin: 0 0 1rem; color: #1e3a8a; }
  .tagline { font-size: 1.25rem; color: #6b7280; margin: 0; }
  h2 { font-size: 1.75rem; margin: 0 0 1.5rem; color: #111827; }

  .story { padding: 2rem 0; max-width: 48rem; margin: 0 auto; }
  .story p { line-height: 1.8; color: #374151; margin: 0 0 1rem; }

  .values { padding: 3rem 0; }
  .values-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; }
  .value-card { background: #f0f9ff; padding: 2rem; border-radius: 0.75rem; border: 1px solid #bfdbfe; }
  .value-card h3 { color: #2563eb; margin: 0 0 0.75rem; }
  .value-card p { color: #374151; line-height: 1.6; margin: 0; }

  .owner { padding: 3rem 0; }
  .owner-card {
    display: flex; gap: 1.5rem; align-items: flex-start; max-width: 48rem;
    padding: 2rem; border: 1px solid #e5e7eb; border-radius: 0.75rem;
  }
  .owner-avatar {
    width: 4rem; height: 4rem; background: #2563eb; color: white; border-radius: 50%;
    display: flex; align-items: center; justify-content: center; font-weight: 700;
    font-size: 1.25rem; flex-shrink: 0;
  }
  .owner-card h3 { margin: 0 0 0.25rem; color: #111827; }
  .role { color: #2563eb; font-weight: 600; margin: 0 0 0.75rem; font-size: 0.875rem; }
  .owner-card p:last-child { color: #6b7280; line-height: 1.6; margin: 0; }

  .cta-section {
    text-align: center; padding: 3rem 2rem; background: #f0f9ff;
    border-radius: 1rem; margin: 2rem 0;
  }
  .cta-section p { color: #374151; margin: 0 0 1.5rem; font-size: 1.1rem; }
  .cta-btn {
    display: inline-block; background: #2563eb; color: white; padding: 0.75rem 2rem;
    border-radius: 0.5rem; text-decoration: none; font-weight: 600; font-size: 1.1rem;
  }
  .cta-btn:hover { background: #1e40af; }
</style>

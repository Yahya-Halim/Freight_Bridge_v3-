---
import Base from '@engine/layouts/Base.astro';
import { getEntry, getCollection } from 'astro:content';

const businessEntry = await getEntry('business', 'biz');
const business = businessEntry?.data;
const locations = await getCollection('locations');
---

<Base title={`Service Areas | ${business?.name}`} description={`${business?.name} provides freight and logistics services nationwide with regional hubs across the United States.`}>
  <section class="hero">
    <h1>Service Areas</h1>
    <p class="subtitle">Nationwide freight coverage with regional hubs for faster, more efficient service</p>
  </section>

  <section class="locations-grid">
    {locations.map((location) => (
      <div class="location-card">
        <div class="location-header">
          <span class="location-icon">📍</span>
          <div>
            <h2>{location.data.city}, {location.data.state}</h2>
            <span class="location-slug">{location.data.slug.replace(/-/g, ' ')}</span>
          </div>
        </div>
        <div class="services-offered">
          <h3>Services Available</h3>
          <ul>
            {location.data.servicesOffered.map((s) => (
              <li>
                <a href={`/services/${s}`}>{s.replace(/-/g, ' ')}</a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    ))}
  </section>

  <section class="coverage">
    <h2>Nationwide Coverage</h2>
    <p class="coverage-text">
      With strategic hubs across the Northeast, Southeast, Midwest, and West Coast,
      {business?.name} delivers freight to every major U.S. market. Our distributed
      network means shorter transit times, lower costs, and better service no matter
      where your shipment needs to go.
    </p>
    <div class="coverage-stats">
      <div class="cov-stat">
        <span class="cov-value">5</span>
        <span class="cov-label">Regional Hubs</span>
      </div>
      <div class="cov-stat">
        <span class="cov-value">50</span>
        <span class="cov-label">States Served</span>
      </div>
      <div class="cov-stat">
        <span class="cov-value">24/7</span>
        <span class="cov-label">Operations</span>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <h2>Need Freight Service in Your Area?</h2>
    <p>Contact us to learn how {business?.name} can serve your logistics needs.</p>
    <a href="/contact" class="cta-btn">Get a Quote</a>
  </section>
</Base>

<style>
  .hero {
    padding: 4rem 0 2rem;
    text-align: center;
  }
  h1 {
    font-size: 2.5rem;
    margin: 0 0 1rem;
    color: #1e3a8a;
  }
  .subtitle {
    font-size: 1.2rem;
    color: #6b7280;
    margin: 0;
  }
  h2 {
    font-size: 1.75rem;
    color: #111827;
    margin: 0 0 1.5rem;
  }

  .locations-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.5rem;
    padding: 2rem 0;
  }
  .location-card {
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    padding: 1.5rem;
    transition: border-color 0.2s;
  }
  .location-card:hover {
    border-color: #2563eb;
  }
  .location-header {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }
  .location-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }
  .location-header h2 {
    font-size: 1.25rem;
    margin: 0;
    color: #1e3a8a;
  }
  .location-slug {
    font-size: 0.8rem;
    color: #6b7280;
    text-transform: capitalize;
  }
  .services-offered h3 {
    font-size: 0.8rem;
    text-transform: uppercase;
    color: #6b7280;
    margin: 0 0 0.5rem;
    letter-spacing: 0.05em;
  }
  .services-offered ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .services-offered li a {
    display: inline-block;
    padding: 0.375rem 0.75rem;
    background: #f0f9ff;
    color: #2563eb;
    border-radius: 0.375rem;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    text-transform: capitalize;
  }
  .services-offered li a:hover {
    background: #dbeafe;
  }

  .coverage {
    padding: 3rem 0;
    text-align: center;
  }
  .coverage-text {
    max-width: 40rem;
    margin: 0 auto 2rem;
    color: #374151;
    line-height: 1.7;
  }
  .coverage-stats {
    display: flex;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
  }
  .cov-stat {
    text-align: center;
  }
  .cov-value {
    display: block;
    font-size: 2.5rem;
    font-weight: 800;
    color: #2563eb;
  }
  .cov-label {
    font-size: 0.9rem;
    color: #6b7280;
  }

  .cta-section {
    text-align: center;
    padding: 3rem 2rem;
    background: #f0f9ff;
    border-radius: 1rem;
    margin: 2rem 0;
  }
  .cta-section p {
    color: #374151;
    margin: 0 0 1.5rem;
    font-size: 1.1rem;
  }
  .cta-btn {
    display: inline-block;
    background: #2563eb;
    color: white;
    padding: 0.75rem 2rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
  }
  .cta-btn:hover {
    background: #1e40af;
  }
</style>

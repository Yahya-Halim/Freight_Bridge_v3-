---
import Base from '@engine/layouts/Base.astro';
import { getEntry, getCollection } from 'astro:content';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((service) => ({
    params: { slug: service.data.slug },
    props: { service: service.data },
  }));
}

const { service } = Astro.props;
const businessEntry = await getEntry('business', 'biz');
const business = businessEntry?.data;

const iconMap: Record<string, string> = {
  'data-center-construction': '🏗️',
  'materials-logistics': '🚛',
  'electrical-infrastructure': '⚡',
  'mechanical-systems': '❄️',
  'site-preparation': '🏔️',
};
---

<Base title={service.seo.title} description={service.seo.description}>
  <section class="hero">
    <span class="hero-icon">{iconMap[service.slug] ?? '📦'}</span>
    <h1>{service.name}</h1>
    <p class="description">{service.description}</p>
    <a href="/contact" class="cta-btn">Call Mohamed at the Office: {business?.phone}</a>
  </section>

  {service.faqs && service.faqs.length > 0 && (
    <section class="faq">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        {service.faqs.map((faq) => (
          <details class="faq-item">
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </div>
    </section>
  )}

  {service.crossLinks && service.crossLinks.length > 0 && (
    <section class="related">
      <h2>Related Services</h2>
      <div class="related-grid">
        {service.crossLinks.map((link) => (
          <a href={`/services/${link.slug}`} class="related-card">
            <span class="related-icon">{iconMap[link.slug] ?? '📦'}</span>
            <span>{link.anchor}</span>
            <span class="arrow">→</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="cta-section">
    <h2>Ready for {service.name}?</h2>
    <p>Contact {business?.name} today for a quote on your data center post-construction cleanup.</p>
    <div class="cta-buttons">
      <a href="/contact" class="cta-btn primary">Request a Quote</a>
      <a href={`tel:${business?.phone}`} class="cta-btn secondary">Call {business?.phone}</a>
    </div>
  </section>
</Base>

<style>
  .hero { padding: 4rem 0 2rem; text-align: center; }
  .hero-icon { font-size: 3.5rem; display: block; margin-bottom: 1rem; }
  h1 { font-size: 2.5rem; margin: 0 0 1rem; color: #1e3a5f; }
  .description { max-width: 40rem; margin: 0 auto 2rem; color: #374151; line-height: 1.7; font-size: 1.1rem; }
  h2 { font-size: 1.75rem; color: #111827; margin: 0 0 1.5rem; }
  .cta-btn { display: inline-block; background: #f59e0b; color: #0f172a; padding: 0.75rem 2rem; border-radius: 0.5rem; text-decoration: none; font-weight: 600; }
  .cta-btn:hover { background: #d97706; }
  .faq { padding: 3rem 0; max-width: 48rem; margin: 0 auto; }
  .faq-list { display: flex; flex-direction: column; gap: 0.75rem; }
  .faq-item { border: 1px solid #e5e7eb; border-radius: 0.5rem; overflow: hidden; }
  .faq-item summary { padding: 1rem 1.5rem; cursor: pointer; font-weight: 600; color: #111827; background: #f9fafb; }
  .faq-item summary:hover { background: #fef3c7; }
  .faq-item p { padding: 1rem 1.5rem; margin: 0; color: #374151; line-height: 1.6; border-top: 1px solid #e5e7eb; }
  .related { padding: 3rem 0; }
  .related-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1rem; }
  .related-card { display: flex; align-items: center; gap: 1rem; padding: 1.25rem 1.5rem; border: 1px solid #e5e7eb; border-radius: 0.5rem; text-decoration: none; color: #111827; font-weight: 600; transition: border-color 0.2s; }
  .related-card:hover { border-color: #f59e0b; }
  .related-icon { font-size: 1.5rem; }
  .arrow { margin-left: auto; color: #f59e0b; }
  .cta-section { text-align: center; padding: 3rem 2rem; background: #1e3a5f; color: white; border-radius: 1rem; margin: 2rem 0; }
  .cta-section h2 { color: white; }
  .cta-section p { color: #cbd5e1; margin: 0 0 1.5rem; font-size: 1.1rem; }
  .cta-buttons { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .cta-btn.primary { background: #f59e0b; color: #0f172a; }
  .cta-btn.secondary { background: transparent; color: white; border: 2px solid white; }
</style>
